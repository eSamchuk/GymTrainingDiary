<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @*<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" integrity="sha384-JcKb8q3iqJ61gNV9KGb8thSsNjpSL0n8PARn9HuZOnIxN0hoP+VmmDGMN5t9UJ0Z" crossorigin="anonymous">*@
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar-dark bg-dark">

        <div class="nav">
            @Html.ActionLink("Gym training workbook", "Index", "Home", new { area = "" }, new { @class = "nav-item nav-link" })
            @Html.ActionLink("Home", "Index", "Home", new { @class = "nav-item nav-link" })
            @Html.ActionLink("Users", "Index", "Users", new { @class = "nav-item nav-link" })
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>

            @RenderSection("OptionalFooter", required: false)

        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
